{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "postinstall": "node -e \"const fs = require('fs'); const file = './node_modules/pdf-parse/index.js'; if (fs.existsSync(file)) { fs.writeFileSync(file, fs.readFileSync(file, 'utf8').replace('let isDebugMode = !module.parent;', 'let isDebugMode = false;')); }\""
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "groq-sdk": "^1.3.0",
    "mammoth": "^1.12.0",
    "multer": "^2.0.0-rc.4",
    "pdf-parse": "1.1.1",
    "react-example": "file:.."
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
